#mvpp .promise b{color:var(--ink);font-weight:600}\n#mvpp .hl{background:linear-gradient(transparent 58%,var(--sage-tint) 58%);padding:0 1px;font-weight:600;color:var(--ink)}\n#mvpp .hlw{background:linear-gradient(transparent 56%,var(--honey-tint) 56%);padding:0 2px;font-weight:600;color:var(--ink)}\n#mvpp .benefits{list-style:none;margin:18px 0 4px;padding:0;display:flex;flex-direction:column;gap:11px}\n#mvpp .benefits li{display:flex;gap:11px;align-items:flex-start;font-size:14.5px;color:var(--ink);line-height:1.45}\n#mvpp .benefits li .bem{font-size:18px;line-height:1.15;flex-shrink:0;width:22px;text-align:center;margin-top:1px}\n#mvpp .benefits li b{font-weight:600}\n#mvpp .reassure{background:var(--sage-tint);border:1px solid #CFE0DD;border-radius:11px;padding:12px 14px;font-size:13px;color:var(--ink);line-height:1.45;margin:18px 0 2px}\n#mvpp .gift-head{font-family:'Jost';font-size:11px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-soft);margin:24px 0 10px;display:flex;align-items:center;gap:8px}\n#mvpp .gift-head .pv{margin-left:auto;color:var(--sage);background:var(--sage-tint);font-size:10px;padding:3px 9px;border-radius:var(--pill);letter-spacing:.04em}\n#mvpp .gifts{display:flex;gap:8px;margin:22px 0}\n#mvpp .gift{flex:1;text-align:center}\n#mvpp .gift .g-badge{display:inline-block;background:var(--ink);color:#fff;font-family:'Jost';font-size:9px;font-weight:600;letter-spacing:.04em;padding:3px 9px;border-radius:var(--pill);margin-bottom:7px}\n#mvpp .ill{position:relative;border:1px solid var(--line);border-radius:var(--r);overflow:hidden;background:var(--cream)}\n#mvpp .ill svg{display:block;width:100%;height:100%}\n#mvpp .gift .ill{aspect-ratio:1;border-radius:11px;margin-bottom:6px}\n#mvpp .gift small{font-size:9.5px;color:var(--ink-soft);line-height:1.25;display:block}\n#mvpp .field-label{font-family:'Jost';font-size:11px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-soft);margin:20px 0 9