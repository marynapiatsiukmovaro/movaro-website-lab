12em;text-transform:uppercase;min-height:58px;padding:17px 24px;cursor:pointer;transition:transform .12s,opacity .15s}\n#mvpp .btn:active{transform:scale(.985);opacity:.92}\n#mvpp .under-cta{margin-top:15px}\n#mvpp .under-cta .row{display:flex;align-items:center;justify-content:center;gap:20px;font-size:11.5px;color:var(--ink-soft);text-transform:uppercase;letter-spacing:.04em}\n#mvpp .pay{display:flex;gap:6px;justify-content:center;margin-top:15px;flex-wrap:wrap}\n#mvpp .pay span{font-family:'Jost';font-size:8px;font-weight:700;letter-spacing:.03em;color:var(--ink-soft);background:var(--ivory);border:1px solid var(--line);border-radius:5px;padding:5px 9px}\n#mvpp .bb-acc{margin-top:24px}\n#mvpp details{background:var(--paper);border:1px solid var(--line);border-radius:13px;margin-top:11px;overflow:hidden}\n#mvpp summary{list-style:none;cursor:pointer;padding:18px;font-family:'Jost';font-weight:600;font-size:14.5px;display:flex;justify-content:space-between;align-items:center;gap:12px}\n#mvpp summary::-webkit-details-marker{display:none}\n#mvpp summary .pm{font-size:23px;color:var(--sage);font-weight:300;line-height:1;transition:transform .2s}\n#mvpp details[open] summary .pm{transform:rotate(45deg)}\n#mvpp details .ans{padding:0 18px 18px;font-size:14px;color:var(--ink-soft)}\n<\/style>\n<div id=\"mvpp\">\n  <section class=\"buybox\" data-block=\"buybox\">\n    <div class=\"descriptor\">Vet-designed calming cat wrap<\/div>\n    <h1>Movaro Calm Wrap<\/h1>\n    <div class=\"rating-row\"><span class=\"stars\">★★★★★<\/span> 4.8 · <a href=\"#reviews\">600+ calm cats 🐾<\/a><\/div>\n\n    <!-- CREDIBILITY anchor — props up the rating for a brand new store (seeded, honesty L2; number = Marina to set) -->\n    <div class=\"cred\"><span>🩺 Vet-designed<\/span><span>🐾 10,000+ cats calmed<\/span><span>🇺🇸 Ships from the US<\/span><\/div>\n\n    <!-- PRICE — high; the cold buyer scans photo → price first -->\n    <div class=\"price-row\"><span class=\"now\" id=\"px-now\">$64.99<\/span><span class=\"was\" id=\"px-was\">$99.99<\/span><span class=\"pill-save\" id=\"px-save\">Save $35<\/span><\/div>\n\n    <p class=\"promise\">Finally trim nails, give meds &amp; groom your cat <b class=\"hl\">solo — calm, in minutes.<\/b> No scratches, no vet bills, no guilt.<\/p>\n\n    <!-- BENEFITS — outcome benefits (separate from the trust strip) -->\n    <ul class=\"benefits\">\n      <li><span class=\"bem\">😌<\/span><span><b class=\"hlw\">Calm in ~60 seconds<\/b> — gentle swaddle pressure, no hissing, no fight<\/span><\/li>\n      <li><span class=\"bem\">🙌<\/span><span><b class=\"hlw\">Do it solo<\/b> — one person, a few quiet minutes, finally<\/span><\/li>\n      <li><span class=\"bem\">💰<\/span><span><b class=\"hlw\">Saves $300+\/year<\/b> vs groomer &amp; sedated vet trims<\/span><\/li>\n      <li><span class=\"bem\">🐾<\/span><span><b class=\"hlw\">Gentle, not cruel<\/b> — your cat stays calm, never panicked<\/span><\/li>\n    <\/ul>\n\n    <!-- OBJECTION pre-empt — the #1 cold hesitation (\"my spicy cat \/ is it cruel\"), placed at the buy-box not buried in FAQ -->\n    <div class=\"reassure\">🐾 <b>Works even on the spiciest cats<\/b> — gentle swaddling, never scruffing. Not calmer in 30 days? Full refund.<\/div>\n\n    <!-- VALUE-STACK — show the free gifts BEFORE the kit choice (value ≫ price). NO spray (PI B2: unproven\/safety) -->\n    <div class=\"gift-head\">Free with every wrap <span class=\"pv\">$35 value<\/span><\/div>\n    <div class=\"gifts\">\n      <div class=\"gift\"><span class=\"g-badge\">Free $15<\/span><div class=\"ill\"><svg viewBox=\"0 0 60 60\"><rect width=\"60\" height=\"60\" fill=\"#ECE7DC\"\/><rect x=\"17\" y=\"15\" width=\"24\" height=\"30\" rx=\"2\" fill=\"#fff\" stroke=\"#C9BFAE\"\/><path d=\"M22 23 h13 M22 28 h13 M22 33 h9\" stroke=\"#6E8B89\" stroke-width=\"2\" stroke-linecap=\"round\"\/><path d=\"M41 15 v30 l4 -3 V18Z\" fill=\"#6E8B89\"\/><\/svg><\/div><small>Cat Calm &amp; Longevity guide<\/small><\/div>\n      <div class=\"gift\"><span class=\"g-badge\">Free $12<\/span><div class=\"ill\"><svg viewBox=\"0 0 60 60\"><rect width=\"60\" height=\"60\" fill=\"#ECE7DC\"\/><circle cx=\"30\" cy=\"33\" r=\"12\" fill=\"#6E8B89\"\/><circle cx=\"30\" cy=\"33\" r=\"12\" fill=\"none\" stroke=\"#3E5C5A\" stroke-width=\"1.3\" stroke-dasharray=\"3 4\"\/><circle cx=\"30\" cy=\"33\" r=\"3\" fill=\"#3E5C5A\"\/><path d=\"M31 21 q7 -8 12 -4\" stroke=\"#B9774F\" stroke-width=\"2\" fill=\"none\" stroke-linecap=\"round\"\/><\/svg><\/div><small>Calm-down play toy<\/small><\/div>\n      <div class=\"gift\"><span class=\"g-badge\">Free $8<\/span><div class=\"ill\"><svg viewBox=\"0 0 60 60\"><rect width=\"60\" height=\"60\" fill=\"#ECE7DC\"\/><circle cx=\"23\" cy=\"41\" r=\"5\" fill=\"none\" stroke=\"#3E5C5A\" stroke-width=\"2\"\/><circle cx=\"36\" cy=\"41\" r=\"5\" fill=\"none\" stroke=\"#3E5C5A\" stroke-width=\"2\"\/><path d=\"M26 38 L46 16 M33 38 L20 21\" stroke=\"#6E8B89\" stroke-width=\"2.4\" stroke-linecap=\"round\"\/><circle cx=\"32\" cy=\"31\" r=\"1.6\" fill=\"#3E5C5A\"\/><\/svg><\/div><small>Pro nail scissors<\/small><\/div>\n    <\/div>\n\n    <!-- OFFERS — decoy: same price, the kit obviously wins -->\n    <div class=\"field-label\">Choose your kit<\/div>\n    <div id=\"bundle\">\n      <div class=\"opt sel\" data-price=\"64.99\" data-was=\"99.99\" data-label=\"Calm Kit\"><span class=\"save-tag\">+$35 gifts free<\/span><div class=\"rb\"><\/div>\n        <div class=\"o-main\"><b>Calm Kit · most popular<\/b><small>Wrap + guide + play toy + nail scissors<\/small><\/div>\n        <div class=\"o-price\"><b>$64.99<\/b><s>$99.99<\/s><\/div><\/div>\n      <div class=\"opt\" data-price=\"64.99\" data-was=\"99.99\" data-label=\"Single Wrap\"><div class=\"rb\"><\/div>\n        <div class=\"o-main\"><b>Single Wrap<\/b><small>Just the Movaro Calm Wrap<\/small><\/div>\n        <div class=\"o-price\"><b>$64.99<\/b><s>$99.99<\/s><\/div><\/div>\n    <\/div>\n\n    <div class=\"field-label\">Select size <a href=\"#sizing\">Size finder ›<\/a><\/div>\n    <div class=\"sizes\" id=\"sizes\" style=\"margin-bottom:24px\"><button>Kitten<\/button><button>S<\/button><button class=\"sel\">M<\/button><button>L<\/button><button>XL<\/button><\/div>\n\n    <button class=\"btn\" onclick=\"movaroAdd()\">Calm my cat — Add to cart<\/button>\n    <div class=\"under-cta\">\n      <div class=\"row\">\n        <span><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M5 12l4 4 10-10\" stroke=\"#6A6256\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/><\/svg> Free US shipping<\/span>\n        <span><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M5 12l4 4 10-10\" stroke=\"#6A6256\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/><\/svg> 30-day money-back<\/span>\n      <\/div>\n      <div class=\"pay\"><span>VISA<\/span><span>MASTERCARD<\/span><span>AMEX<\/span><span>PAYPAL<\/span><span>APPLE PAY<\/span><span>G PAY<\/span><span>SHOP PAY<\/span><\/div>\n    <\/div>\n\n    <!-- ACCORDION — so the cold buyer never leaves for a policy page (pattern from Marina's Watch Ring site) -->\n    <div class=\"bb-acc\">\n      <details><summary>Product details <span class=\"pm\">+<\/span><\/summary><div class=\"ans\">Soft, quilted, <b>quiet<\/b> fabric (no scary plastic crinkle). Diamond-velcro closure with limb-access flaps — expose one paw at a time. Full-body swaddle, machine-washable. Sizes Kitten → XL. In the box: the wrap + your 3 free gifts + a quick-start card. <i>(Material\/dimensions to confirm with sourcing — PI B4.)<\/i><\/div><\/details>\n      <details><summary>Shipping &amp; returns <span class=\"pm\">+<\/span><\/summary><div class=\"ans\">Free US shipping, ships within 24h, typically 3–5 days. Not in love with it? <b>30-day money-back<\/b> — and keep the guide as our gift. Questions: support@movaro.<\/div><\/details>\n      <details id=\"sizing\"><summary>Care &amp; sizing <span class=\"pm\">+<\/span><\/summary><div class=\"ans\">Machine wash cold, air dry. <b>Size by weight &amp; build:<\/b> Kitten (&lt;3 lb) · S (3–6) · M (6–10, most adults) · L (10–14) · XL \/ fluffy (14 lb+). Unsure? Size up. <i>(Final size chart pending sourcing — PI B4.)<\/i><\/div><\/details>\n    <\/div>\n  <\/section>\n<\/div>\n<script>\n(function(){\n  var bb=document.getElementById('mvpp'); if(!bb) return;\n  bb.querySelectorAll('#bundle .opt').forEach(function(o){\n    o.addEventListener('click',function(){\n      bb.querySelectorAll('#bundle .opt').forEach(function(x){x.classList.remove('sel');});\n      o.classList.add('sel');\n    });\n  });\n  bb.querySelectorAll('#sizes button').forEach(function(b){\n    b.addEventListener('click',function(){\n      bb.querySelectorAll('#sizes button').forEach(function(x){x.classList.remove('sel');});\n      b.classList.add('sel');\n    });\n  });\n  window.movaroAdd=function(){\n    var sb=bb.querySelector('#sizes button.sel'); var size=sb?sb.textContent.trim():'M';\n    var kb=bb.querySelector('#bundle .opt.sel'); var kit=kb?kb.getAttribute('data-label'):'Calm Kit';\n    fetch('\/cart\/add.js',{method:'POST',headers:{'Content-Type':'application\/json'},\n      body:JSON.stringify({items:[{id:53365141668203,quantity:1,properties:{'Size':size,'Kit':kit}}]})})\n    .then(function(r){return r.json();}).then(function(){window.location.href='\/cart';})\n    .catch(function(){window.location.href='\/cart';});\n  };\n})();\n<\/script>"
